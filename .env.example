# === Model Service URLs (internal Docker network) ===
EMBEDDING_URL=http://embedding:8001
RERANKER_URL=http://reranker:8002
GUARD_URL=http://guard:8003
QDRANT_URL=http://qdrant:6333
QDRANT_COLLECTION=econ_vn_news

# === Remote LLM (vLLM on vast.ai) ===
LLM_URL=http://your-remote-ip:8004

# === Retrieval Configuration ===
RETRIEVAL_TOP_K=20
RERANK_TOP_N=5

# === Web Search Fallback ===
TAVILY_API_KEY=your-tavily-api-key-here
TAVILY_MAX_RESULTS=5
FALLBACK_MIN_CHUNKS=3
FALLBACK_SCORE_THRESHOLD=0.5

# === Timeout Configuration (seconds) ===
GUARD_TIMEOUT_S=10
LLM_TIMEOUT_S=60
EMBEDDING_TIMEOUT_S=15
RERANKER_TIMEOUT_S=15

# === Messages ===
APOLOGY_MESSAGE="Xin lỗi, tôi không thể trả lời câu hỏi này vì nó có vẻ không an toàn hoặc vi phạm chính sách nội dung của chúng tôi."

# === Hugging Face (for model downloads inside containers) ===
HUGGING_FACE_HUB_TOKEN=your-hf-token-here

# === Cloudflare Tunnel ===
CLOUDFLARE_TUNNEL_TOKEN=your-cloudflare-tunnel-token-here

# === Open WebUI ===
OPENAI_API_BASE_URL=http://orchestrator:8000/v1
OPENAI_API_KEY=dummy
WEBUI_AUTH=false
