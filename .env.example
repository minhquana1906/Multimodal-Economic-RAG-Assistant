# === Docker Registry ===
DOCKERHUB_NAMESPACE=your-dockerhub-namespace
IMAGE_TAG=latest

# === LLM Backend ===
LLM__URL=http://ollama:11434/v1
LLM__MODEL=Qwen/Qwen3.5-4B
LLM__TEMPERATURE=0.7
LLM__MAX_TOKENS=2048
LLM__TIMEOUT=60.0
# LLM__API_KEY=

# === Service Configuration ===
SERVICES__INFERENCE_URL=http://inference:8001
SERVICES__INFERENCE_TIMEOUT=30.0
SERVICES__QDRANT_URL=http://qdrant:6333
SERVICES__QDRANT_COLLECTION=econ_vn_news

# === Ingestion ===
INGEST__BATCH_SIZE=256
INGEST__FORCE_RECREATE=false

# === RAG Tuning ===
RAG__RETRIEVAL_TOP_K=20
RAG__RERANK_TOP_N=5
RAG__WEB_FALLBACK_MIN_CHUNKS=2
RAG__WEB_FALLBACK_HARD_THRESHOLD=0.70
RAG__WEB_FALLBACK_SOFT_THRESHOLD=0.85
RAG__CONTEXT_LIMIT=5
RAG__CITATION_LIMIT=5

# === Observability ===
OBSERVABILITY__LOG_LEVEL=INFO
OBSERVABILITY__LANGSMITH_API_KEY=
OBSERVABILITY__LANGSMITH_PROJECT=multimodal-economic-rag
OBSERVABILITY__TAVILY_API_KEY=

# === Hugging Face ===
HF_TOKEN=your-hf-token-here

# === OpenWebUI Configuration ===
WEBUI_DEFAULT_MODELS=Multimodal-Economic-RAG
WEBUI_SECRET_KEY=change-me

# === Cloudflare Tunnel ===
CLOUDFLARE_TUNNEL_TOKEN=your-cloudflare-tunnel-token-here
