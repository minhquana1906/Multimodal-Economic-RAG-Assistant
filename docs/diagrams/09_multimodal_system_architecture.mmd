            qdrant["Qdrant<br/>econ_vn_news<br/>econ_knowledge"]
        end

        subgraph fs["Local Data Store"]
            raw["data/raw"]
            parsed["data/parsed"]
            images["data/images"]
        end
    end

    subgraph remote["Remote Services / Internet"]
        llm["vLLM / Qwen3.5-4B<br/>:8004"]
        vlm["VLM / Qwen3-VL-4B<br/>:8007"]
