# === Image registry ===
DOCKERHUB_NAMESPACE=your-dockerhub-namespace
IMAGE_TAG=latest

# === Inference backends ===
LLM__URL=http://llm:8004/v1
LLM__MODEL=Qwen/Qwen3-4B-Instruct
VLM_MODEL=Qwen/Qwen3-VL-4B-Instruct
VLLM_LLM_GPU_MEMORY_UTILIZATION=0.45
VLLM_VLM_GPU_MEMORY_UTILIZATION=0.45
VLLM_LLM_MAX_MODEL_LEN=8192
VLLM_VLM_MAX_MODEL_LEN=4096

# === Service Models ===
SERVICES__EMBEDDING_MODEL=Qwen/Qwen3-Embedding-0.6B
SERVICES__RERANKER_MODEL=Qwen/Qwen3-Reranker-0.6B
SERVICES__GUARD_MODEL=Qwen/Qwen3Guard-Gen-0.6B
SERVICES__ASR_MODEL=Qwen/Qwen3-ASR-1.7B
SERVICES__TTS_MODEL=pnnbao-ump/VieNeu-TTS

# === Service URLs (only override if you change hostnames) ===
# SERVICES__EMBEDDING_URL=http://embedding:8001
# SERVICES__RERANKER_URL=http://reranker:8002
# SERVICES__GUARD_URL=http://guard:8003
# SERVICES__QDRANT_URL=http://qdrant:6333

# === App tuning ===
SERVICES__MAX_SEQ_LENGTH=1024
SERVICES__ENCODE_BATCH_SIZE=128
SERVICES__ASR_MAX_DURATION_S=60
SERVICES__ASR_IDLE_TIMEOUT=300
SERVICES__TTS_IDLE_TIMEOUT=300
SERVICES__TTS_SAMPLE_RATE=24000
SERVICES__TTS_SPEED=1.0
QDRANT_COLLECTION=econ_vn_news

# === Auth / external services ===
OPENAI_API_KEY=dummy
WEBUI_SECRET_KEY=change-me
HUGGING_FACE_HUB_TOKEN=your-hf-token-here
CLOUDFLARE_TUNNEL_TOKEN=your-cloudflare-tunnel-token-here
OBSERVABILITY__LOG_LEVEL=INFO
OBSERVABILITY__LANGSMITH_API_KEY=
OBSERVABILITY__LANGSMITH_PROJECT=multimodal-economic-rag
OBSERVABILITY__TAVILY_API_KEY=
