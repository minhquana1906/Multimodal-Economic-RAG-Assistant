                RERANK["Reranker Service<br/>Qwen3-Reranker-0.6B<br/>:8002 (~1.2 GB)"]
                GUARD["Guard Service<br/>Qwen3Guard-Gen-0.6B<br/>:8003 (~1.2 GB)"]
            end

            subgraph Phase2["Phase 2 (profile: audio)"]
                ASR["ASR Service<br/>Qwen3-ASR-1.7B<br/>:8005 (~3.4 GB)"]
            end
        end

        QDRANT_VOL[("qdrant_storage<br/>Named Volume")]
    end

    subgraph RemoteGPU["🌐 Remote GPU (vast.ai)"]
        LLM["vLLM Server<br/>Qwen3.5-4B<br/>:8004 (~8 GB)"]
        VLM["Phase 3: VLM<br/>Qwen3-VL-4B<br/>:8006 (~8 GB)"]
    end

    %% External connections
    CF_DNS -->|"HTTPS"| TUNNEL
    TUNNEL -->|"HTTP"| WEBUI

    %% Internal connections
    WEBUI -->|"POST /v1/chat/completions<br/>(OpenAI-compatible)"| ORCH
    ORCH -->|"POST /classify"| GUARD
    ORCH -->|"POST /embed"| EMB
    ORCH -->|"Hybrid Search<br/>(dense + sparse)"| QDRANT
    ORCH -->|"POST /rerank"| RERANK
    ORCH -->|"POST /v1/chat/completions<br/>(SSH/Tailscale)"| LLM
    ORCH -.->|"tavily-python SDK"| TAVILY

    %% Storage
    QDRANT --- QDRANT_VOL

    %% Future phases
    ORCH -.->|"Phase 2"| ASR
    ORCH -.->|"Phase 3"| VLM

