---
title: "Hybrid Retrieval, Provenance, And Citation Flow"
---
flowchart LR
    MSGS["request.messages"]

    subgraph Conversation["Backend Conversation Prep"]
        NORMALIZE["Normalize messages"]
        SUMMARIZE["summary + recent policy<br/>summarize only when threshold and budget require it"]
        REWRITE["Rewrite follow-up into resolved_query"]
        RAW["raw_query for UX + final answer prompt"]
    end

    subgraph DensePath["Dense Query Path"]
        DENSE_ENC["Embedding service<br/>prompt_name='query'<br/>resolved_query -> 1024-dim vector"]
    end

    subgraph SparsePath["Sparse Query Path"]
        VN_TOK["underthesea.word_tokenize<br/>(format='text')"]
        BM25["SparseEncoderService<br/>Bm25('Qdrant/bm25')<br/>resolved_query -> indices / values"]
    end

    subgraph Retrieval["Qdrant Retrieval"]
        HYBRID["hybrid_search(dense, sparse)<br/>vector names: dense + sparse"]
        DENSE_ONLY["dense-only fallback<br/>when sparse encoder fails"]
        RETRIEVED["Retrieved chunks"]
    end

    subgraph Ranking["Ranking + Fallback"]
        RERANK["Reranker scores passages sequentially<br/>using resolved_query"]
        WEB_CHECK{"Need web fallback?<br/>chunk_count < min OR top_score < threshold"}
        WEB["Tavily search(resolved_query)"]
    end

    subgraph Provenance["Context + Provenance"]
        CONTEXT["Build final_context entries<br/>context_id, source_type, retrieval_stage,<br/>collection/doc/chunk/modality metadata"]
        POOL["citation_pool keyed by context_id"]
    end

    subgraph Generation["Generation + Citation Rendering"]
        PROMPT["Prompt = conversation_context + source metadata + raw_query<br/>LLM cites with [[cite:context_id]]"]
        REPAIR["Validate placeholders<br/>repair once if needed"]
        RENDER["Render inline citations<br/>[title](url) or title (source)"]
        OUTPUT["Exact answer text for message.content<br/>or byte-for-byte delta.content streaming"]
    end

    METRICS["Embedding / Reranker / Guard log<br/>latency + GPU memory snapshots"]

    MSGS --> NORMALIZE --> SUMMARIZE --> REWRITE
    NORMALIZE --> RAW
    REWRITE --> DENSE_ENC
    REWRITE --> VN_TOK --> BM25
    SUMMARIZE --> PROMPT
    RAW --> PROMPT

    DENSE_ENC --> HYBRID
    BM25 --> HYBRID
    DENSE_ENC --> DENSE_ONLY
    HYBRID --> RETRIEVED
    DENSE_ONLY --> RETRIEVED
    RETRIEVED --> RERANK --> WEB_CHECK
    WEB_CHECK -->|"Yes"| WEB
    WEB_CHECK -->|"No"| CONTEXT
    WEB --> CONTEXT
    CONTEXT --> POOL
    CONTEXT --> PROMPT
    PROMPT --> REPAIR --> RENDER --> OUTPUT
    POOL --> REPAIR

    METRICS -.-> DENSE_ENC
    METRICS -.-> RERANK

    classDef convo fill:#e0f2fe,stroke:#0284c7,stroke-width:2px
    classDef dense fill:#dbeafe,stroke:#2563eb,stroke-width:2px
    classDef sparse fill:#fef3c7,stroke:#d97706,stroke-width:2px
    classDef retrieval fill:#ede9fe,stroke:#7c3aed,stroke-width:2px
    classDef ranking fill:#dcfce7,stroke:#16a34a,stroke-width:2px
    classDef provenance fill:#fee2e2,stroke:#dc2626,stroke-width:2px
    classDef generation fill:#fce7f3,stroke:#db2777,stroke-width:2px
    classDef metrics fill:#ecfccb,stroke:#65a30d,stroke-width:2px

    class NORMALIZE,SUMMARIZE,REWRITE,RAW convo
    class DENSE_ENC dense
    class VN_TOK,BM25 sparse
    class HYBRID,DENSE_ONLY,RETRIEVED retrieval
    class RERANK,WEB_CHECK,WEB ranking
    class CONTEXT,POOL provenance
    class PROMPT,REPAIR,RENDER,OUTPUT generation
    class METRICS metrics
