# === LLM Backend ===
LLM__URL=http://localhost:8004
LLM__MODEL=Qwen/Qwen3.5-4B
# LLM__TEMPERATURE=0.7
# LLM__MAX_TOKENS=512

# === Service URLs (override if not using default docker-compose hostnames) ===
# SERVICES__EMBEDDING_URL=http://embedding:8001
# SERVICES__RERANKER_URL=http://reranker:8002
# SERVICES__GUARD_URL=http://guard:8003
# SERVICES__QDRANT_URL=http://qdrant:6333

# === Service Models (passed into GPU containers) ===
SERVICES__EMBEDDING_MODEL=Qwen/Qwen3-Embedding-0.6B
SERVICES__RERANKER_MODEL=Qwen/Qwen3-Reranker-0.6B
SERVICES__GUARD_MODEL=Qwen/Qwen3Guard-Gen-0.6B

# === RAG Tuning ===
# RAG__RETRIEVAL_TOP_K=20
# RAG__RERANK_TOP_N=5

# === Observability ===
OBSERVABILITY__LOG_LEVEL=INFO
OBSERVABILITY__LANGSMITH_API_KEY=your-langsmith-api-key-here
OBSERVABILITY__LANGSMITH_PROJECT=multimodal-economic-rag
OBSERVABILITY__TAVILY_API_KEY=your-tavily-api-key-here

# === Hugging Face (for model downloads inside containers) ===
HUGGING_FACE_HUB_TOKEN=your-hf-token-here

# === Cloudflare Tunnel ===
CLOUDFLARE_TUNNEL_TOKEN=your-cloudflare-tunnel-token-here
