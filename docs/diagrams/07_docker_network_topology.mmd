---
title: "Docker Network Topology & Container Dependencies"
---
graph TB
    subgraph PublicInternet["🌐 Public Internet"]
        USER["User Browser<br/>quannguyen.works"]
        CF["Cloudflare CDN/DNS"]
        TAVILY_API["Tavily API<br/>(external)"]
    end

    subgraph LocalHost["🖥️ Local Host Machine"]
        subgraph RagNet["Docker Bridge Network: rag-net"]
            direction TB

            subgraph FrontendTier["Frontend Tier"]
                TUNNEL["cloudflared<br/>Cloudflare Tunnel<br/><i>No GPU</i>"]
                WEBUI["Open WebUI<br/>:8080<br/><i>No GPU</i>"]
            end

            subgraph OrchestratorTier["Orchestrator Tier"]
                ORCH["FastAPI Orchestrator<br/>:8000<br/><i>No GPU</i><br/>depends_on: healthy"]
            end

            subgraph DataTier["Data Tier"]
                QDRANT["Qdrant Vector DB<br/>:6333 (HTTP) / :6334 (gRPC)<br/><i>No GPU</i>"]
            end

            subgraph MLTier["ML Services (Local GPU)"]
                EMB["Embedding<br/>:8001<br/><i>GPU ~1.2 GB</i>"]
                RERANK["Reranker<br/>:8002<br/><i>GPU ~1.2 GB</i>"]
                GUARD["Guard<br/>:8003<br/><i>GPU ~1.2 GB</i>"]
            end

            subgraph Phase2Tier["Phase 2 Services (profile: audio)"]
                ASR["ASR<br/>:8005<br/><i>GPU ~3.4 GB</i>"]
            end
        end

        subgraph Volumes["Persistent Storage"]
            QDRANT_VOL[("qdrant_storage<br/>Named Volume")]
        end

        ENV[".env<br/>HF_TOKEN<br/>TAVILY_API_KEY<br/>CLOUDFLARE_TUNNEL_TOKEN<br/>LLM_URL"]
    end

    subgraph RemoteGPU["🌐 Remote GPU (vast.ai)"]
        LLM_REMOTE["vLLM: Qwen3.5-4B<br/>:8004<br/><i>GPU ~8 GB</i>"]
        VLM_REMOTE["Phase 3: VLM<br/>:8006<br/><i>GPU ~8 GB</i>"]
    end

    %% Public connections
    USER -->|"HTTPS"| CF
    CF -->|"Tunnel"| TUNNEL
    TUNNEL -->|"HTTP"| WEBUI

    %% Internal connections
    WEBUI -->|"POST /v1/chat/completions"| ORCH

    %% Orchestrator to services
    ORCH -->|"POST /embed"| EMB
    ORCH -->|"POST /rerank"| RERANK
    ORCH -->|"POST /classify"| GUARD
    ORCH -->|"Hybrid query"| QDRANT
    ORCH -.->|"Phase 2"| ASR
    ORCH -.->|"tavily-python"| TAVILY_API

    %% Remote connections
    ORCH -->|"SSH tunnel / Tailscale<br/>POST /v1/chat/completions"| LLM_REMOTE
    ORCH -.->|"Phase 3"| VLM_REMOTE

    %% Storage
    QDRANT ---|"mount"| QDRANT_VOL

    %% Health check dependencies
    ORCH -.-|"healthcheck"| EMB
    ORCH -.-|"healthcheck"| RERANK
    ORCH -.-|"healthcheck"| GUARD
    ORCH -.-|"healthcheck"| QDRANT

    %% Styling
    classDef gpu fill:#fef3c7,stroke:#f59e0b,stroke-width:2px
    classDef nogpu fill:#dbeafe,stroke:#3b82f6,stroke-width:2px
    classDef future fill:#e5e7eb,stroke:#9ca3af,stroke-dasharray:5 5
    classDef external fill:#fce7f3,stroke:#ec4899
    classDef storage fill:#d1fae5,stroke:#10b981,stroke-width:2px

    class EMB,RERANK,GUARD,LLM_REMOTE gpu
    class TUNNEL,WEBUI,ORCH,QDRANT nogpu
    class ASR,VLM_REMOTE future
    class USER,CF,TAVILY_API external
    class QDRANT_VOL storage
