flowchart TD
    start([Start]) --> detect{"Input modality?"}

    detect -->|Audio| asr["ASR<br/>audio -> text"]
    detect -->|Image| vlm["VLM / OCR<br/>image -> text"]
    detect -->|Text| text["Text input"]

    asr --> normalize
    vlm --> normalize
    text --> normalize

    normalize["Backend conversation prep<br/>normalize messages + classify task<br/>summary + recent + resolved_query"] --> task{"Auxiliary task?"}

    task -->|Yes| aux["Backend auxiliary prompt<br/>title / tags / follow_ups"]
    task -->|No| input_guard["Input guard<br/>resolved_query"]

    input_guard -->|Unsafe| stop1([Stop: safe denial])
    input_guard -->|Safe| embed["Dense embed<br/>resolved_query"]
    embed --> sparse["Sparse encode<br/>underthesea + BM25"]
    sparse --> retrieve["Hybrid retrieve<br/>dense + sparse"]
    sparse --> dense_only["Dense-only fallback<br/>on sparse encoder error"]
    dense_only --> retrieve

    retrieve --> rerank["Rerank passages sequentially"]
    rerank --> fallback{"Need web fallback?"}
    fallback -->|Yes| web["Tavily search<br/>resolved_query"]
    fallback -->|No| combine["Build final_context<br/>+ citation_pool"]
    web --> combine

    combine --> generate["Generate answer<br/>conversation_context + raw_query<br/>+ [[cite:context_id]] instructions"]
    generate --> output_guard["Output guard<br/>prompt = resolved_query"]
    output_guard -->|Blocked twice| stop2([Stop: safe denial])
    output_guard -->|Safe| citations["Validate / repair citations<br/>render inline markdown links"]

    citations --> trace["Trace compact root output<br/>answer + citations + task_type + resolved_query"]
    aux --> trace

    trace --> format{"Response format?"}
    format -->|Text| end1([End: message.content or exact delta.content stream])
    format -->|Audio| tts["TTS synthesize"]
    tts --> end2([End: text + audio])

    metrics["Guard / Embedding / Reranker<br/>log latency + GPU memory metrics"] -.-> input_guard
    metrics -.-> embed
    metrics -.-> rerank

    classDef step fill:#dbeafe,stroke:#2563eb,color:#0f172a
    classDef transform fill:#dcfce7,stroke:#16a34a,color:#14532d
    classDef decision fill:#fef3c7,stroke:#d97706,color:#7c2d12
    classDef final fill:#fee2e2,stroke:#dc2626,color:#7f1d1d
    classDef metrics fill:#ecfccb,stroke:#65a30d,color:#365314

    class normalize,input_guard,embed,sparse,dense_only,retrieve,rerank,combine,generate,output_guard,citations,trace step
    class asr,vlm,web,tts,aux,metrics transform
    class detect,task,fallback,format decision
    class start,stop1,stop2,end1,end2 final
