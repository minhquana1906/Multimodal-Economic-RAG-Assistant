---
title: "Data Ingestion Pipeline — scripts/ingest.py"
---
flowchart TD
    START(["Start: scripts/ingest.py"]) --> CHECK_COLL

    CHECK_COLL{"Collection 'econ_vn_news'\nexists with expected\npoint count?"}
    CHECK_COLL -->|"Yes"| SKIP["Skip ingestion<br/>(idempotent)"]
    CHECK_COLL -->|"No"| LOAD_DS

    SKIP --> DONE(["Done"])

    LOAD_DS["Load Dataset<br/>datasets.load_dataset('khoalnd/EconVNNews')<br/>308,933 articles"]
    LOAD_DS --> CREATE_COLL

    CREATE_COLL["Create Qdrant Collection<br/>dense: 1024-dim vector<br/>sparse: BM25 with IDF modifier"]
    CREATE_COLL --> ITER_ARTICLES

    ITER_ARTICLES["Iterate Articles<br/>(batch processing)"]
    ITER_ARTICLES --> CHUNK

    subgraph ChunkingStrategy["Semantic Chunking per Article"]
        CHUNK["Parse Article"]
        CHUNK --> TITLE_LEAD

        TITLE_LEAD["Create title_lead chunk<br/>= title + first paragraph"]
        TITLE_LEAD --> BODY_PARAS

        BODY_PARAS["Create body_paragraph chunks<br/>= each subsequent paragraph"]
        BODY_PARAS --> MERGE_SHORT

        MERGE_SHORT{"Paragraph<br/>< 50 chars?"}
        MERGE_SHORT -->|"Yes"| MERGE["Merge with<br/>preceding paragraph"]
        MERGE_SHORT -->|"No"| KEEP["Keep as<br/>separate chunk"]
        MERGE --> ASSIGN_META
        KEEP --> ASSIGN_META

        ASSIGN_META["Assign Metadata<br/>article_id: hash(url)<br/>chunk_type, chunk_index<br/>title, url, date, author<br/>category, source"]
    end

    ASSIGN_META --> BATCH_COLLECT

    BATCH_COLLECT{"Batch full?<br/>(~256 chunks)"}
    BATCH_COLLECT -->|"No"| ITER_ARTICLES
    BATCH_COLLECT -->|"Yes"| ENCODE

    subgraph Vectorization["Vectorization"]
        ENCODE["Dense Encoding<br/>Qwen3-Embedding-0.6B<br/>via Embedding Service :8001<br/>(no prompt_name for docs)"]
        ENCODE --> VN_TOKENIZE

        VN_TOKENIZE["Vietnamese Tokenization<br/>underthesea.word_tokenize(text)<br/>per chunk"]
        VN_TOKENIZE --> SPARSE_ENCODE

        SPARSE_ENCODE["Sparse Encoding<br/>fastembed with Qdrant/bm25<br/>(pre-tokenized input)"]
    end

    SPARSE_ENCODE --> UPSERT

    UPSERT["Batch Upsert to Qdrant<br/>dense + sparse vectors<br/>+ full payload"]
    UPSERT --> MORE

    MORE{"More articles?"}
    MORE -->|"Yes"| ITER_ARTICLES
    MORE -->|"No"| DONE

    %% Styling
    classDef process fill:#dbeafe,stroke:#3b82f6,stroke-width:2px
    classDef decision fill:#fef3c7,stroke:#f59e0b,stroke-width:2px
    classDef terminal fill:#d1fae5,stroke:#10b981,stroke-width:2px
    classDef chunk fill:#ede9fe,stroke:#8b5cf6,stroke-width:1px

    class LOAD_DS,CREATE_COLL,ITER_ARTICLES,ENCODE,VN_TOKENIZE,SPARSE_ENCODE,UPSERT process
    class CHECK_COLL,MERGE_SHORT,BATCH_COLLECT,MORE decision
    class START,DONE,SKIP terminal
    class CHUNK,TITLE_LEAD,BODY_PARAS,MERGE,KEEP,ASSIGN_META chunk
