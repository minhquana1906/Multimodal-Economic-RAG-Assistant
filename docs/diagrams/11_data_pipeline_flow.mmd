flowchart TB
    subgraph Stage1["STAGE 1: CRAWL & COLLECT"]
        web_crawl["Web Crawlers<br/>(httpx + BS4)"]
        pdf_crawl["PDF Downloaders<br/>(requests + Selenium)"]
        acad_crawl["Academic Scrapers<br/>(Selenium + httpx)"]

        web_crawl --> raw_store
        pdf_crawl --> raw_store
        acad_crawl --> raw_store

        raw_store[("data/raw/{source}/<br/>{date}/{hash}.html|pdf")]
    end

    subgraph Stage2["STAGE 2: PARSE & EXTRACT"]
        html_parse["HTML Parser<br/>(trafilatura + BS4)"]
        pdf_parse["PDF Parser<br/>(pdfplumber + PyMuPDF)"]
        vis_extract["Visual Extractor<br/>(detect charts/tables)"]

        raw_store --> html_parse
        raw_store --> pdf_parse
        pdf_parse --> vis_extract

        html_parse --> parsed_store
        pdf_parse --> parsed_store
        vis_extract --> image_store

        parsed_store[("data/parsed/{source}/<br/>{hash}.json")]
        image_store[("data/images/<br/>{hash}_{pg}_{i}.png")]
    end

    subgraph Stage3["STAGE 3: CHUNK & ENRICH"]
        text_chunk["Text Chunker<br/>• title_lead<br/>• body_paragraph<br/>• section_content<br/>• definition"]

        vlm_table["VLM /extract-table<br/>→ markdown table"]
        vlm_chart["VLM /describe-chart<br/>→ text description<br/>+ key insights"]

        parsed_store --> text_chunk
        image_store --> classify{"Table or<br/>Chart?"}
        classify -->|"table<br/>(grid lines)"| vlm_table
        classify -->|"chart<br/>(no grid)"| vlm_chart

        text_chunk --> unified
        vlm_table --> unified
        vlm_chart --> unified

        unified["Unified Chunks<br/>[{chunk_id, doc_id,<br/>chunk_type, text,<br/>image_path, metadata}]"]
    end

    subgraph Stage4["STAGE 4: EMBED & INDEX"]
        embed_dense["Embedding Service<br/>dense vector (1024d)"]
        embed_sparse["BM25 Tokenizer<br/>sparse vector<br/>(underthesea)"]

        unified --> embed_dense
        unified --> embed_sparse

        embed_dense --> qdrant
        embed_sparse --> qdrant

        qdrant[("Qdrant<br/>Collection: econ_knowledge<br/>• dense + sparse vectors<br/>• full payload<br/>• image_path ref")]
    end

    %% Styling
    classDef crawl fill:#e74c3c,color:#fff
    classDef parse fill:#3498db,color:#fff
    classDef enrich fill:#2ecc71,color:#fff
    classDef index fill:#9b59b6,color:#fff
    classDef store fill:#f39c12,color:#333

    class web_crawl,pdf_crawl,acad_crawl crawl
    class html_parse,pdf_parse,vis_extract parse
    class text_chunk,vlm_table,vlm_chart,classify enrich
    class embed_dense,embed_sparse index
    class raw_store,parsed_store,image_store,unified,qdrant store
