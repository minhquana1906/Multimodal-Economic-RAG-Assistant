# === Docker Registry ===
DOCKERHUB_NAMESPACE=your-dockerhub-namespace
IMAGE_TAG=latest

# === LLM Backend ===
LLM__URL=http://llm:8004/v1
# LLM__MODEL=Qwen/Qwen3.5-4B                              # bf16 (base, ~8GB)
# LLM__MODEL=<your-hf-namespace>/Qwen3.5-4B-W4A16-G128    # after quantize-vlm
LLM__MODEL=Qwen/Qwen3.5-4B
LLM__TEMPERATURE=0.7
LLM__MAX_TOKENS=1024
LLM__TIMEOUT=60.0
LLM__API_KEY=dummy
# Vision settings (multimodal image input)
LLM__ENABLE_VISION=true
LLM__MAX_IMAGE_PIXELS=1048576
LLM__MAX_IMAGE_BYTES=4000000
LLM__IMAGE_DETAIL=auto
LLM__MAX_IMAGES_PER_TURN=4

# === vLLM Runtime Tuning ===
# For Qwen3.5-4B multimodal on RTX 3090 (vast.ai):
#   vllm serve $LLM__MODEL --dtype bfloat16 \
#     --limit-mm-per-prompt '{"image":4,"video":0}' \
#     --trust-remote-code --max-model-len 32768 --port 8004 \
#     --quantization compressed-tensors  # if using quantized checkpoint
VLLM__MAX_MODEL_LEN=32768
VLLM__MAX_NUM_BATCHED_TOKENS=4096
VLLM__MAX_NUM_SEQS=8
VLLM__GPU_MEMORY_UTILIZATION=0.92
VLLM__DTYPE=bfloat16
VLLM__KV_CACHE_DTYPE=auto
VLLM__QUANTIZATION=compressed-tensors


# === Service Configuration ===
SERVICES__INFERENCE_URL=http://inference:8001
SERVICES__INFERENCE_TIMEOUT=30.0
SERVICES__QDRANT_URL=http://qdrant:6333
SERVICES__QDRANT_COLLECTION=academic_chunks

# === Ingestion ===
INGEST__BATCH_SIZE=256
INGEST__FORCE_RECREATE=false

# === RAG Tuning ===
RAG__RETRIEVAL_TOP_K=20
RAG__RERANK_TOP_N=5
RAG__WEB_FALLBACK_MIN_CHUNKS=2
RAG__WEB_FALLBACK_HARD_THRESHOLD=0.70
RAG__WEB_FALLBACK_SOFT_THRESHOLD=0.85
RAG__CONTEXT_LIMIT=5
RAG__CITATION_LIMIT=5

# === OpenWebUI Configuration ===
WEBUI_DEFAULT_MODELS=Economic-RAG-Assistant
WEBUI_SECRET_KEY=admin

# === Observability ===
OBSERVABILITY__LOG_LEVEL=INFO
OBSERVABILITY__APP_MODE=dev  # dev | prod (default: prod) — set to dev for verbose LLM response logging
OBSERVABILITY__LANGSMITH_API_KEY=Your-LangSmith-API-Key-Here
OBSERVABILITY__LANGSMITH_PROJECT=multimodal-economic-rag
OBSERVABILITY__TAVILY_API_KEY=Your-Tavily-API-Key-Here

# === Hugging Face ===
HF_TOKEN=your-hf-token-here

# === Qdrant Snapshot (public HF dataset repo) ===
SNAPSHOT_HF_REPO=quannguyen204/economic-rag-snapshots
SNAPSHOT_FILENAME=academic_chunks-3178864631652020-2026-04-20-08-40-03.snapshot

# === Cloudflare Tunnel ===
CLOUDFLARE_TUNNEL_TOKEN=your-cloudflare-tunnel-token-here
